<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<AnchorPane xmlns="http://javafx.com/javafx"
                        xmlns:fx="http://javafx.com/fxml"
                        fx:controller="tn.esprit.controllers.equipe.EquipeDashboardController"
                        prefHeight="600.0" prefWidth="900.0"
                        style="-fx-background-color: #0f172a;">

        <VBox spacing="20"
              AnchorPane.topAnchor="20" AnchorPane.leftAnchor="20"
              AnchorPane.rightAnchor="20" AnchorPane.bottomAnchor="20">

            <HBox alignment="CENTER_LEFT">
                <Label text="Equipes Management"
                       style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: white;"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Button text="+ New Equipe" onAction="#handleNewEquipe"
                        style="-fx-background-color: #7c3aed; -fx-text-fill: white;
                               -fx-font-size: 14px; -fx-pref-height: 40px;
                               -fx-pref-width: 160px; -fx-cursor: hand;
                               -fx-background-radius: 8;"/>
            </HBox>

            <HBox spacing="15">
                <VBox alignment="CENTER" prefWidth="200" prefHeight="90"
                      style="-fx-background-color: #1e293b; -fx-background-radius: 10;">
                    <Label fx:id="totalEquipesLabel" text="0"
                           style="-fx-font-size: 30px; -fx-font-weight: bold; -fx-text-fill: #7c3aed;"/>
                    <Label text="TOTAL EQUIPES"
                           style="-fx-text-fill: #94a3b8; -fx-font-size: 12px;"/>
                </VBox>
            </HBox>

            <HBox spacing="10" alignment="CENTER_LEFT">
                <TextField fx:id="searchField" promptText="Rechercher (nom, logo, id...)"
                           style="-fx-pref-width: 320; -fx-pref-height: 36;
                                  -fx-background-color: #1e293b; -fx-text-fill: white;
                                  -fx-prompt-text-fill: #94a3b8; -fx-background-radius: 8;"/>
                <ComboBox fx:id="sortCombo"
                          style="-fx-pref-width: 220; -fx-pref-height: 36;
                                 -fx-background-color: #1e293b; -fx-background-radius: 8;"/>
            </HBox>

            <TableView fx:id="equipeTable" VBox.vgrow="ALWAYS"
                       style="-fx-background-color: #1e293b;">
                <columns>
                                   <TableColumn fx:id="nomCol" text="NOM" prefWidth="290"/>
                                   <TableColumn fx:id="maxMembersCol" text="MAX MEMBERS" prefWidth="160"/>
                                   <TableColumn fx:id="logoCol" text="LOGO" prefWidth="270"/>
                                   <TableColumn fx:id="actionsCol" text="ACTIONS" prefWidth="180"/>
                </columns>
            </TableView>

            <Label fx:id="messageLabel" text="" style="-fx-font-size: 13px;"/>

    </VBox>
</AnchorPane>
