<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.layout.VBox?>

<AnchorPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="tn.esprit.controllers.equipe.AjouterEquipeController"
            prefHeight="320.0" prefWidth="430.0"
            style="-fx-background-color: #0f172a;">

    <VBox spacing="14"
          AnchorPane.topAnchor="25" AnchorPane.leftAnchor="35"
          AnchorPane.rightAnchor="35" AnchorPane.bottomAnchor="25">

        <Label fx:id="titleLabel" text="Ajouter une equipe"
               style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: white;"/>

        <Label text="Nom" style="-fx-text-fill: #94a3b8;"/>
        <TextField fx:id="nomField" promptText="Ex: Team Phoenix"
                   style="-fx-background-color: #1e293b; -fx-text-fill: white; -fx-pref-height: 38px;"/>

        <Label text="Max members" style="-fx-text-fill: #94a3b8;"/>
        <TextField fx:id="maxMembersField" promptText="Ex: 11"
                   style="-fx-background-color: #1e293b; -fx-text-fill: white; -fx-pref-height: 38px;"/>

       <Label text="Logo" style="-fx-text-fill: #94a3b8;"/>
       <HBox spacing="8" alignment="CENTER_LEFT">
           <TextField fx:id="logoField" promptText="Ex: team-phoenix.png"
                     style="-fx-background-color: #1e293b; -fx-text-fill: white; -fx-pref-height: 38px;"
                     HBox.hgrow="ALWAYS"/>
           <Button text="Parcourir" onAction="#handleBrowseLogo"
                  style="-fx-background-color: #334155; -fx-text-fill: white;
                        -fx-pref-width: 110px; -fx-pref-height: 38px; -fx-cursor: hand;"/>
       </HBox>

        <Label fx:id="messageLabel" text="" style="-fx-font-size: 13px;"/>

        <HBox spacing="10" alignment="CENTER_RIGHT">
            <Button text="Annuler" onAction="#handleCancel"
                    style="-fx-background-color: #e74c3c; -fx-text-fill: white;
                           -fx-pref-width: 110px; -fx-pref-height: 38px; -fx-cursor: hand;"/>
            <Button fx:id="submitBtn" text="Ajouter" onAction="#handleSubmit"
                    style="-fx-background-color: #7c3aed; -fx-text-fill: white;
                           -fx-pref-width: 110px; -fx-pref-height: 38px; -fx-cursor: hand;"/>
        </HBox>

    </VBox>
</AnchorPane>
