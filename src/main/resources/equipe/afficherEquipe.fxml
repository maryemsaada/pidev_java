<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
    fx:controller="tn.esprit.controllers.equipe.AfficherEquipeController"
      prefHeight="720.0" prefWidth="1280.0"
    spacing="10"
    style="-fx-background-color: #0b1330; -fx-padding: 10;">

    <fx:include source="/Navbar.fxml"/>

    <VBox alignment="TOP_CENTER" spacing="12" style="-fx-padding: 16 24 18 24;" VBox.vgrow="ALWAYS">
        <HBox alignment="CENTER_LEFT" prefWidth="1140" spacing="10">
            <Label text="Active Rosters" style="-fx-font-size: 36px; -fx-font-weight: 800; -fx-text-fill: #8b5cf6;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <HBox alignment="CENTER" spacing="4"
                  style="-fx-background-color: #1b2547; -fx-padding: 6 12; -fx-background-radius: 16;">
                <Label text="Total:" style="-fx-text-fill: #94a3b8; -fx-font-weight: 700;"/>
                <Label fx:id="totalTeamsLabel" text="0" style="-fx-text-fill: #ec4899; -fx-font-weight: 800;"/>
            </HBox>
            <Button text="Ajouter equipe" onAction="#handleAddEquipe"
                    style="-fx-background-color: #22c55e; -fx-text-fill: white; -fx-font-size: 14px;
                           -fx-font-weight: 700; -fx-background-radius: 12; -fx-cursor: hand;
                           -fx-pref-height: 38; -fx-pref-width: 150;"/>
        </HBox>

             <HBox alignment="CENTER_LEFT" spacing="10" prefWidth="1140">
                 <TextField fx:id="searchField" promptText="Rechercher une equipe..."
                      style="-fx-pref-width: 320; -fx-pref-height: 36;
                          -fx-background-color: #1b2547; -fx-text-fill: #e5e7eb;
                          -fx-prompt-text-fill: #94a3b8; -fx-background-radius: 10;"/>
                 <ComboBox fx:id="sortCombo"
                     style="-fx-pref-width: 220; -fx-pref-height: 36;
                         -fx-background-color: #1b2547; -fx-background-radius: 10;"/>
             </HBox>

        <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
                    style="-fx-background: transparent; -fx-background-color: transparent;">
            <content>
                <FlowPane fx:id="cardsContainer" alignment="TOP_LEFT" hgap="14" vgap="14" prefWrapLength="1140"/>
            </content>
        </ScrollPane>

        <Label fx:id="messageLabel" text="" style="-fx-text-fill: #f87171; -fx-font-size: 13px;"/>
    </VBox>
</VBox>
