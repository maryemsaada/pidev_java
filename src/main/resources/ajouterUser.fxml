<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="tn.esprit.controllers.AjouterUserController"
            prefHeight="360.0" prefWidth="420.0"
            style="-fx-background-color: #0f172a;">

    <VBox spacing="12"
          AnchorPane.topAnchor="25" AnchorPane.leftAnchor="35"
          AnchorPane.rightAnchor="35" AnchorPane.bottomAnchor="25">

        <Label fx:id="titleLabel" text="Ajouter Utilisateur"
               style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: white;"/>

        <Label text="Nom" style="-fx-text-fill: #94a3b8;"/>
        <TextField fx:id="nomField" promptText="Ex: Ahmed"
                   style="-fx-background-color: #1e293b; -fx-text-fill: white; -fx-pref-height: 38px;"/>
        <Label fx:id="nomError" text="" visible="false" managed="false"
               style="-fx-font-size: 11px; -fx-text-fill: #ef4444; -fx-padding: 4 0 0 0;"/>

        <Label text="Email" style="-fx-text-fill: #94a3b8;"/>
        <TextField fx:id="emailField" promptText="Ex: user@email.com"
                   style="-fx-background-color: #1e293b; -fx-text-fill: white; -fx-pref-height: 38px;"/>
        <Label fx:id="emailError" text="" visible="false" managed="false"
               style="-fx-font-size: 11px; -fx-text-fill: #ef4444; -fx-padding: 4 0 0 0;"/>

        <Label text="Password" style="-fx-text-fill: #94a3b8;"/>
        <PasswordField fx:id="passwordField" promptText="Password"
                       style="-fx-background-color: #1e293b; -fx-text-fill: white; -fx-pref-height: 38px;"/>
        <Label fx:id="passwordError" text="" visible="false" managed="false"
               style="-fx-font-size: 11px; -fx-text-fill: #ef4444; -fx-padding: 4 0 0 0;"/>

        <Label text="Roles" style="-fx-text-fill: #94a3b8;"/>
        <TextField fx:id="rolesField" promptText='["ROLE_USER"]'
                   style="-fx-background-color: #1e293b; -fx-text-fill: white; -fx-pref-height: 38px;"/>
        <Label fx:id="rolesError" text="" visible="false" managed="false"
               style="-fx-font-size: 11px; -fx-text-fill: #ef4444; -fx-padding: 4 0 0 0;"/>

        <CheckBox fx:id="activeCheckBox" text="Utilisateur actif"
                  style="-fx-text-fill: white;"/>

        <Label fx:id="messageLabel" text="" style="-fx-font-size: 13px;"/>

        <HBox spacing="10" alignment="CENTER_RIGHT">
            <Button text="Annuler" onAction="#handleCancel"
                    style="-fx-background-color: #e74c3c; -fx-text-fill: white;
                           -fx-pref-width: 110px; -fx-pref-height: 38px; -fx-cursor: hand;"/>
            <Button fx:id="submitBtn" text="Ajouter" onAction="#handleSubmit"
                    style="-fx-background-color: #7c3aed; -fx-text-fill: white;
                           -fx-pref-width: 110px; -fx-pref-height: 38px; -fx-cursor: hand;"/>
        </HBox>

    </VBox>
</AnchorPane>
