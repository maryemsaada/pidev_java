<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="tn.esprit.controllers.AfficherProduitsController"
            prefHeight="700.0" prefWidth="1000.0"
            style="-fx-background-color: #0d1b3e;">

    <VBox spacing="20"
          AnchorPane.topAnchor="20" AnchorPane.leftAnchor="20"
          AnchorPane.rightAnchor="20" AnchorPane.bottomAnchor="20">

        <!-- HEADER -->
        <VBox spacing="3">
            <Label text="HARDWARE DEPOT"
                   style="-fx-text-fill: #7c3aed; -fx-font-size: 13px; -fx-font-weight: bold;"/>
            <Label text="GAMING GEAR"
                   style="-fx-text-fill: white; -fx-font-size: 28px; -fx-font-weight: bold;"/>
        </VBox>

        <!-- SEARCH -->
        <HBox spacing="10" alignment="CENTER_LEFT">
            <TextField fx:id="searchField" promptText="Search gear..."
                       prefWidth="400" prefHeight="42"
                       style="-fx-background-color: #1e293b; -fx-text-fill: white;
                              -fx-prompt-text-fill: #64748b;
                              -fx-background-radius: 8; -fx-font-size: 14px;"/>
            <Button text="🔍" onAction="#handleSearch"
                    style="-fx-background-color: #f1f5f9; -fx-font-size: 16px;
                           -fx-pref-height: 42px; -fx-pref-width: 42px;
                           -fx-cursor: hand; -fx-background-radius: 8;"/>
        </HBox>

        <!-- CONTENT -->
        <HBox spacing="20" VBox.vgrow="ALWAYS">

            <!-- CATEGORIES SIDEBAR -->
            <VBox spacing="10" prefWidth="220" minWidth="220"
                  style="-fx-background-color: #1e3a5f; -fx-background-radius: 15;
                         -fx-padding: 20;">
                <Label text="CATEGORIES"
                       style="-fx-text-fill: white; -fx-font-size: 16px;
                              -fx-font-weight: bold;"/>
                <Button text="Tous" onAction="#showAll" maxWidth="Infinity"
                        style="-fx-background-color: #7c3aed; -fx-text-fill: white;
                               -fx-pref-height: 38px; -fx-cursor: hand;
                               -fx-background-radius: 20; -fx-font-size: 13px;"/>
                <VBox fx:id="categoriesBox" spacing="8"/>
            </VBox>

            <!-- PRODUCTS -->
            <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS" HBox.hgrow="ALWAYS"
                        style="-fx-background-color: transparent; -fx-background: #0d1b3e;">
                <FlowPane fx:id="productsContainer" hgap="20" vgap="20"
                          prefWrapLength="700"
                          style="-fx-background-color: transparent; -fx-padding: 10;"/>
            </ScrollPane>

        </HBox>
    </VBox>
</AnchorPane>